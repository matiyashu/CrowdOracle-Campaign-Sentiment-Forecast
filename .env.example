# ============================================================
# CrowdOracle / BigBrother Campaign Sentiment Forecast
# Environment Variables — copy to .env and fill in values
# ============================================================

# ── MiroFish core (required for simulation/graph features) ──
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
ZEP_API_KEY=

# ── Flask ────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
FLASK_DEBUG=true

# ── Database ─────────────────────────────────────────────────
# Defaults to SQLite (fine for local dev)
DATABASE_URL=sqlite:///crowdoracle.db

# ── LLM Provider Registry ────────────────────────────────────
DEFAULT_PROVIDER=openai

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# ── Report Agent tuning (optional) ──────────────────────────
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5

# ── OASIS simulation (optional) ──────────────────────────────
OASIS_DEFAULT_MAX_ROUNDS=10
