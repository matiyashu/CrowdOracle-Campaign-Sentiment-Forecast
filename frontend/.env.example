# ============================================================
# CrowdOracle frontend — Vite env
# Copy to .env.local (dev) or configure in Vercel project env (prod)
# ============================================================

# Backend API origin. Leave blank/unset for local dev — Vite proxies /api
# to http://localhost:5001 via the dev server (see vite.config.js).
# In production, point this at your deployed Flask backend, e.g.
#   VITE_API_BASE_URL=https://crowdoracle-api.onrender.com
VITE_API_BASE_URL=
