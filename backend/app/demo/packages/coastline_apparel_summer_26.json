    { "text": "The new Coastline collection looks incredible — that linen shirt is going in my cart.", "sentiment": "positive", "sentiment_score": 0.82, "aspect": "creative", "emotion": "excitement", "source_platform": "instagram", "author_handle": "@weekendedits", "engagement_count": 412, "created_at_source": "2026-05-03T14:22:00Z", "linked_asset_ref": "hero_sunset" },
    { "text": "Wait the Coastline unboxing is so clean, the fabric looks amazing.", "sentiment": "positive", "sentiment_score": 0.78, "aspect": "quality", "emotion": "joy", "source_platform": "tiktok", "author_handle": "@maria.styles", "engagement_count": 2180, "created_at_source": "2026-05-05T09:11:00Z", "linked_asset_ref": "tiktok_unbox" },
    { "text": "Love the vibe but these prices feel steep for what's essentially a linen tee.", "sentiment": "negative", "sentiment_score": -0.54, "aspect": "price", "emotion": "frustration", "source_platform": "twitter", "author_handle": "@kbudget", "engagement_count": 88, "created_at_source": "2026-05-06T19:47:00Z" },
    { "text": "This lookbook made me book a beach weekend. Well done, @Coastline.", "sentiment": "positive", "sentiment_score": 0.91, "aspect": "creative", "emotion": "joy", "source_platform": "youtube", "author_handle": "@jordanm", "engagement_count": 64, "created_at_source": "2026-05-08T21:05:00Z", "linked_asset_ref": "yt_lookbook" },
    { "text": "Shipping took 12 days and the hat arrived crushed. Not the launch experience I wanted.", "sentiment": "negative", "sentiment_score": -0.72, "aspect": "delivery", "emotion": "frustration", "source_platform": "twitter", "author_handle": "@auholmes", "engagement_count": 133, "created_at_source": "2026-05-10T08:30:00Z" },
    { "text": "The 5-ways-to-style carousel is saved. Genius format.", "sentiment": "positive", "sentiment_score": 0.65, "aspect": "creative", "emotion": "joy", "source_platform": "instagram", "author_handle": "@dressing.room", "engagement_count": 294, "created_at_source": "2026-05-11T15:12:00Z", "linked_asset_ref": "ig_carousel" },
    { "text": "The linen wrinkles immediately. Wish the photos had shown that.", "sentiment": "negative", "sentiment_score": -0.44, "aspect": "quality", "emotion": "frustration", "source_platform": "reddit", "engagement_count": 51, "created_at_source": "2026-05-12T11:04:00Z" },
    { "text": "Their TikToks feel so effortless compared to the usual fast-fashion grind.", "sentiment": "positive", "sentiment_score": 0.58, "aspect": "brand_trust", "emotion": "joy", "source_platform": "tiktok", "engagement_count": 812, "created_at_source": "2026-05-13T20:01:00Z" },
    { "text": "The UK size guide is confusing. Do I order my normal M or go up?", "sentiment": "neutral", "sentiment_score": 0.05, "aspect": "ux", "emotion": "confusion", "source_platform": "instagram", "engagement_count": 22, "created_at_source": "2026-05-14T07:45:00Z" },
    { "text": "My third Coastline haul this year. They just get what summer should feel like.", "sentiment": "positive", "sentiment_score": 0.88, "aspect": "brand_trust", "emotion": "joy", "source_platform": "instagram", "engagement_count": 512, "created_at_source": "2026-05-15T18:22:00Z" },
    { "text": "This is peak marketing, nothing actually new though. Same linen + beach story every brand is doing.", "sentiment": "negative", "sentiment_score": -0.37, "aspect": "creative", "emotion": "frustration", "source_platform": "twitter", "engagement_count": 212, "created_at_source": "2026-05-16T10:30:00Z" },
    { "text": "Ordered the wide-leg trousers in AU — fit is perfect. Finally.", "sentiment": "positive", "sentiment_score": 0.79, "aspect": "quality", "emotion": "joy", "source_platform": "instagram", "engagement_count": 142, "created_at_source": "2026-05-17T13:12:00Z" },
    { "text": "Summer capsule > fast fashion collabs this season, don't @ me.", "sentiment": "positive", "sentiment_score": 0.71, "aspect": "brand_trust", "emotion": "joy", "source_platform": "twitter", "engagement_count": 316, "created_at_source": "2026-05-18T16:48:00Z" },
    { "text": "The YouTube ad plays too loud. Skipped in 3 seconds.", "sentiment": "negative", "sentiment_score": -0.41, "aspect": "ux", "emotion": "frustration", "source_platform": "youtube", "engagement_count": 19, "created_at_source": "2026-05-19T09:50:00Z", "linked_asset_ref": "yt_lookbook" },
    { "text": "Coastline's offer page is finally readable on mobile. Thank you.", "sentiment": "positive", "sentiment_score": 0.55, "aspect": "ux", "emotion": "joy", "source_platform": "twitter", "engagement_count": 44, "created_at_source": "2026-05-20T11:30:00Z" }
